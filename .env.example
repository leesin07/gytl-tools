# 应用配置
NEXT_PUBLIC_APP_NAME=GYTL-Tools
NEXT_PUBLIC_APP_VERSION=1.0.0

# API配置
NEXT_PUBLIC_API_BASE_URL=/api

# 默认筛选条件
NEXT_PUBLIC_DEFAULT_MIN_CHANGE=3
NEXT_PUBLIC_DEFAULT_MAX_CHANGE=8
NEXT_PUBLIC_DEFAULT_MIN_VOLUME_RATIO=1.5
NEXT_PUBLIC_DEFAULT_MIN_TURNOVER_RATE=5
NEXT_PUBLIC_DEFAULT_MAX_TURNOVER_RATE=15
NEXT_PUBLIC_DEFAULT_MIN_MARKET_CAP=0
NEXT_PUBLIC_DEFAULT_MAX_MARKET_CAP=100
NEXT_PUBLIC_DEFAULT_MIN_PRICE=10
NEXT_PUBLIC_DEFAULT_MAX_PRICE=50

# 缓存配置
# 股票列表缓存时间（秒）
NEXT_PUBLIC_STOCK_LIST_CACHE_TIME=60
# 实时行情缓存时间（秒）
NEXT_PUBLIC_QUOTE_CACHE_TIME=5

# 性能配置
# 每次最大查询股票数量
NEXT_PUBLIC_MAX_STOCKS_PER_QUERY=200
# 搜索结果最大数量
NEXT_PUBLIC_MAX_SEARCH_RESULTS=100

# 开发模式
NODE_ENV=production
